# Greffe — fichiers à NE PAS commiter
# Le contenu utilisateur reste local au serveur, jamais dans le repo.

# Tout le contenu local du serveur reste hors du repo,
# sauf le .htaccess qui doit voyager avec le code (protection web).
admin/data/**
!admin/data/.htaccess

# Uploads (fichiers uploadés par les users)
admin/uploads/**
!admin/uploads/.htaccess

# Configuration locale potentielle
.env
.env.local
admin/config.local.php

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
.claude/

# PHP build / temp
*.cache
.phpunit.result.cache

# seed.php est délibérément exclu — anonyme sans auth/CSRF
admin/seed.php

# Recovery one-shot — anonyme par construction, ne JAMAIS committer ni laisser en prod.
admin/_pwreset.php
