# Greffe — fichiers à NE PAS commiter
# Le contenu utilisateur reste local au serveur, jamais dans le repo.

# Tout le contenu local du serveur reste hors du repo,
# sauf le .htaccess qui doit voyager avec le code (protection web).
admin/data/**
!admin/data/.htaccess

# Uploads (fichiers uploadés par les users)
admin/uploads/**
!admin/uploads/.htaccess

# Configuration locale potentielle
.env
.env.local

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
.claude/

# PHP build / temp
*.cache
.phpunit.result.cache
